#!/bin/sh

# ── Autostart ─────────────────────
pgrep -x sxhkd >/dev/null || sxhkd &

# Display settings
xrandr --output VGA-1 --brightness 1.3 --gamma 0.75:0.75:0.75

# Wallpaper
command -v nitrogen >/dev/null && nitrogen --restore &

#pywal
"${HOME}/.cache/wal/colors.sh"


# Audio Relay
$HOME/portable/bin/AudioRelay &

# Compositor
picom &

# Polybar
polybar &

# Eww
eww daemon &

# System tray & auth
command -v kdeconnect-indicator >/dev/null && kdeconnect-indicator &
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 &


# ── Workspaces ────────────────────
bspc monitor -d I II III


# ── Layout ────────────────────────
bspc config top_padding             40
bspc config split_ratio             0.50
bspc config borderless_monocle      false
bspc config gapless_monocle         false
bspc config focus_follows_pointer   true
bspc config pointer_follows_focus   true
bspc config pointer_motion_interval 16


# ── Mouse ─────────────────────────
bspc config pointer_modifier        mod4
bspc config pointer_action1         move
bspc config pointer_action2         resize_side
bspc config pointer_action3         resize_corner


# ── Border & Gap ──────────────────
bspc config border_width            2
bspc config window_gap              6
bspc config normal_border_color     "#3c3836"
bspc config active_border_color     "#504945"
bspc config focused_border_color    "#fe8019"
bspc config presel_feedback_color   "#d79921"


# ── Rules ─────────────────────────
bspc rule -a Polybar    manage=off
bspc rule -a Gimp       state=floating
bspc rule -a Pavucontrol state=floating
bspc rule -a feh        state=floating
bspc rule -a Lxappearance state=floating
bspc rule -a mpv        state=floating
bspc rule -a startup-term state=floating rectangle=500x320+40+80

kitty --class startup-term &


# ── Workspace Animation ────────────
bspc subscribe desktop_focus | while read -r _ _ _ desktop _; do
    for win in $(bspc query -W -d "$desktop"); do
        xdotool windowunmap "$win"
        sleep 0.05
        xdotool windowmap "$win"
    done
done &
